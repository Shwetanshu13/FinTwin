{
  "info": {
    "name": "FinTwin API",
    "description": "Postman collection for FinTwin backend (mounted at / and /api). Set collection variable baseUrl to your backend base (recommended: http://localhost:3000/api or your ngrok URL + /api).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    { "key": "username", "value": "demo_user", "type": "string" },
    { "key": "email", "value": "demo_user@example.com", "type": "string" },
    { "key": "password", "value": "Passw0rd!", "type": "string" },
    { "key": "fullName", "value": "Demo User", "type": "string" },
    { "key": "phone", "value": "", "type": "string" },

    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },

    { "key": "incomeId", "value": "", "type": "string" },
    { "key": "expenseId", "value": "", "type": "string" },
    { "key": "savingId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root (GET /)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "Health (GET /health)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (POST /auth/register)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register status', () => pm.expect(pm.response.code).to.be.oneOf([200, 201, 409]));",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json?.token?.accessToken) pm.collectionVariables.set('accessToken', json.token.accessToken);",
                  "  if (json?.token?.refreshToken) pm.collectionVariables.set('refreshToken', json.token.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"fullName\": \"{{fullName}}\",\n  \"phone\": \"{{phone}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login (POST /auth/login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login status', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json?.token?.accessToken || '');",
                  "pm.collectionVariables.set('refreshToken', json?.token?.refreshToken || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh (POST /auth/refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
                  "const json = pm.response.json();",
                  "if (json?.token?.accessToken) pm.collectionVariables.set('accessToken', json.token.accessToken);",
                  "if (json?.token?.refreshToken) pm.collectionVariables.set('refreshToken', json.token.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Me (GET /auth/me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get profile (GET /profile)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/profile"
          }
        },
        {
          "name": "Update profile (PATCH /profile)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"fullName\": \"{{fullName}}\",\n  \"phone\": \"{{phone}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/profile"
          }
        }
      ]
    },
    {
      "name": "Records",
      "item": [
        {
          "name": "Income - List (GET /records/income)",
          "request": {
