            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"Salary\",\n  \"amount\": 100000,\n  \"frequency\": \"monthly\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/records/income"
          }
        },
        {
          "name": "Income - Update (PATCH /records/income/:id)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 110000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/records/income/{{incomeId}}"
          }
        },
        {
          "name": "Income - Delete (DELETE /records/income/:id)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
